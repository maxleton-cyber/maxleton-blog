<style>
    .cyber-tile-big {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .cyber-tile-big:hover {
        transform: scale(1.03);
        box-shadow: 0 10px 30px rgba(0, 255, 255, 0.2);
    }
</style>
<div class="grid-layout">
    <main>
        <% if (page.posts && page.posts.length > 0) { %>
            <% page.posts.each(function(post) { %>
                <article class="cyber-tile-big fg-dark" style="background-color: var(--dark-gray);padding: 15px 30px;">
                    <div class="post-date">DATA_ID: <%= post.date ? post.date.format('YYYY_MMDD') : '2077_0000' %></div>
                    <h2 class="post-title"><a href="<%= url_for(post.path) %>"><%= post.title %></a></h2>
                    <p class="post-excerpt"><%= strip_html(post.excerpt || post.content).substring(0, 150) %><% if ((post.excerpt || post.content).length > 150) { %>...<% } %></p>
                </article>
            <% }); %>
        <% }%>

        <% if (page.total > 1) { %>
            <nav class="pagination">
                <%- paginator({
                    prev_text: 'PREV',
                    next_text: 'NEXT',
                    show_all: false,
                    mid_size: 2
                }) %>
            </nav>
        <% } %>

    </main>

    <aside>
        <section class="sidebar-section">
            <div class="profile-card">
                <div class="avatar-wrapper">
                    <img src="<%= url_for(theme.avatar || 'https://via.placeholder.com/100') %>" alt="<%= config.author %>" class="avatar-img">
                    <div class="avatar-ring"></div>
                </div>
                <span class="avatar-label">USER_IDENTIFICATION</span>
                <h3 class="user-name"><%= config.author %></h3>
                <p class="user-bio"><%= theme.bio || config.description || 'Netrunner. Dreamer. Leaving for the Moon.' %></p>
                <div style="margin-top: 15px; border-top: 1px solid #333; padding-top: 10px;">
                    <span style="font-size: 0.7rem; color: var(--lucy-pink);">TRACE_PROGRESS: 0%</span>
                </div>
            </div>
        </section>

        <section class="sidebar-section">
            <h4 style="font-family: monospace; margin-bottom: 15px; color: var(--cyber-yellow);">// CATEGORIES</h4>
            <div class="cloud-container">
                <% site.categories.each(function(category) { %>
                    <a href="<%= url_for(category.path) %>" class="cloud-item"><%= category.name %><span class="cloud-count"><%= category.length %></span></a>
                <% }); %>
            </div>
        </section>

        <section class="sidebar-section">
            <h4 style="font-family: monospace; margin-bottom: 15px; color: var(--cyber-yellow);">// TAGS</h4>
            <div class="cloud-container">
                <% site.tags.each(function(tag) { %>
                    <a href="<%= url_for(tag.path) %>" class="cloud-item"><%= tag.name %><span class="cloud-count"><%= tag.length %></span></a>
                <% }); %>
            </div>
        </section>
    </aside>
</div>