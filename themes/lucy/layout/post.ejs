<div class="post-page" style="max-width: 900px; margin: 0 auto; padding: 60px 30px;">
    <article class="post">
        <header class="post-header" style="margin-bottom: 50px; padding-bottom: 30px; border-bottom: 2px solid var(--cyan);">
            <div class="post-meta oxanium-font" style="font-size: 0.85rem; color: var(--cyan); margin-bottom: 20px; opacity: 0.8;">
                <span>DATA_ID: <%= page.date ? page.date.format('YYYY_MMDD') : '2077_0000' %></span>
                <% if (page.categories && page.categories.length > 0) { %>
                    <span style="margin-left: 20px;">CATEGORY: <%= page.categories.toArray()[0].name %></span>
                <% } %>
            </div>
            <h1 class="post-title cyber-h" style="font-size: 2.8rem; color: var(--white); margin: 0; line-height: 1.3;"><%= page.title %></h1>
        </header>
        
        <div class="post-content" style="font-size: 1.1rem; line-height: 1.8; color: var(--white);">
            <%- page.content %>
        </div>
        
        <footer class="post-footer" style="margin-top: 60px; padding-top: 40px; border-top: 1px solid var(--cyan);">
            <% if (page.tags && page.tags.length > 0) { %>
            <div class="post-tags" style="margin-bottom: 40px;">
                <div class="oxanium-font" style="color: var(--red); margin-bottom: 15px; font-size: 0.85rem; opacity: 0.8;">// TAGS</div>
                <% page.tags.each(function(tag) { %>
                    <a href="<%= url_for(tag.path) %>" class="cyber-button-small" style="margin: 5px; text-decoration: none;"><%= tag.name %></a>
                <% }); %>
            </div>
            <% } %>
            
            <nav class="post-nav" style="display: flex; justify-content: space-between; gap: 30px;">
                <% if (page.prev) { %>
                <div class="post-nav-item">
                    <div class="oxanium-font" style="font-size: 0.75rem; color: var(--cyan); margin-bottom: 8px; opacity: 0.7;">&lt;&lt; PREV_DATA</div>
                    <a href="<%= url_for(page.prev.path) %>" class="cyber-a" style="font-size: 1.1rem;"><%= page.prev.title %></a>
                </div>
                <% } else { %>
                <div class="post-nav-item"></div>
                <% } %>
                
                <% if (page.next) { %>
                <div class="post-nav-item" style="text-align: right;">
                    <div class="oxanium-font" style="font-size: 0.75rem; color: var(--cyan); margin-bottom: 8px; opacity: 0.7;">NEXT_DATA &gt;&gt;</div>
                    <a href="<%= url_for(page.next.path) %>" class="cyber-a" style="font-size: 1.1rem;"><%= page.next.title %></a>
                </div>
                <% } else { %>
                <div class="post-nav-item" style="text-align: right;"></div>
                <% } %>
            </nav>
        </footer>
    </article>
</div>

<style>
    .post-content h1, .post-content h2, .post-content h3, 
    .post-content h4, .post-content h5, .post-content h6 {
        color: var(--cyan);
        margin-top: 50px;
        margin-bottom: 20px;
        line-height: 1.4;
    }
    
    .post-content h1 { font-size: 2.2rem; }
    .post-content h2 { font-size: 1.9rem; }
    .post-content h3 { font-size: 1.6rem; }
    .post-content h4 { font-size: 1.4rem; }
    
    .post-content p {
        margin-bottom: 25px;
        color: var(--white);
    }
    
    .post-content a {
        color: var(--cyan);
        text-decoration: none;
        transition: all 0.3s ease;
    }
    
    .post-content a:hover {
        text-shadow: var(--cyan) 0px 0px 1px;
    }
    
    .post-content img {
        max-width: 100%;
        display: block;
        margin: 30px auto;
        border-radius: 3px;
    }
    
    .post-content ul, .post-content ol {
        margin: 25px 0;
        padding-left: 30px;
        color: var(--white);
    }
    
    .post-content li {
        margin-bottom: 12px;
        color: var(--white);
    }
    
    .post-content blockquote {
        border-left: 4px solid var(--red);
        padding: 15px 25px;
        margin: 30px 0;
        color: var(--white);
        background-color: rgba(255, 0, 60, 0.05);
        font-style: italic;
    }
    
    .post-content blockquote p {
        margin-bottom: 0;
    }
    
    .post-content table {
        width: 100%;
        margin: 30px 0;
        border-collapse: collapse;
    }
    
    .post-content th, .post-content td {
        padding: 12px 15px;
        border: 1px solid var(--cyan);
        text-align: left;
        color: var(--white);
    }
    
    .post-content th {
        background-color: rgba(0, 255, 210, 0.1);
        color: var(--cyan);
    }
    
    .post-content pre {
        background-color: #282c34;
        padding: 20px;
        padding-top: 40px;
        margin: 20px 0;
        overflow-x: auto;
        border-left: 3px solid var(--cyan);
        border-radius: 3px;
        max-height: 430px;
        overflow-y: auto;
        position: relative;
    }
    
    .post-content pre::-webkit-scrollbar {
        height: 8px;
        width: 8px;
    }
    
    .post-content pre::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 4px;
    }
    
    .post-content pre::-webkit-scrollbar-thumb {
        background: transparent !important;
        border-radius: 4px;
        transition: background 0.3s ease;
    }
    
    .post-content pre:hover::-webkit-scrollbar-thumb {
        background: var(--cyan) !important;
    }
    
    .post-content pre:hover::-webkit-scrollbar-thumb:hover {
        background: var(--yellow) !important;
    }
    
    .post-content pre {
        scrollbar-width: thin;
        scrollbar-color: transparent transparent;
    }
    
    .post-content pre:hover {
        scrollbar-color: var(--cyan) transparent;
    }
    
    .code-lang-label {
        position: absolute;
        top: 8px;
        left: 12px;
        padding: 4px 12px;
        background: rgba(0, 255, 210, 0.1);
        color: var(--cyan);
        font-family: 'Consolas', monospace;
        font-size: 0.7rem;
        font-weight: bold;
        border: 1px solid var(--cyan);
        border-radius: 3px;
        z-index: 10;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .post-content pre code {
        display: block;
        white-space: pre;
        word-wrap: normal;
        background: none;
        padding: 0;
    }
    
    .post-content code {
        background-color: rgba(0, 255, 210, 0.1);
        color: var(--cyan);
        padding: 2px 6px;
        font-family: 'Consolas', 'Monaco', monospace;
        border-radius: 3px;
    }
    
    .post-content figure.highlight {
        background-color: #282c34;
        margin: 20px 0;
        padding: 20px;
        padding-top: 40px;
        border-left: 3px solid var(--cyan);
        border-radius: 3px;
        overflow-x: auto;
        position: relative;
        max-height: 600px;
        overflow-y: auto;
    }
    
    .post-content figure.highlight::-webkit-scrollbar {
        height: 8px;
        width: 8px;
    }
    
    .post-content figure.highlight::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 4px;
    }
    
    .post-content figure.highlight::-webkit-scrollbar-thumb {
        background: transparent;
        border-radius: 4px;
    }
    
    .post-content figure.highlight:hover::-webkit-scrollbar-thumb {
        background: var(--cyan);
    }
    
    .post-content figure.highlight:hover::-webkit-scrollbar-thumb:hover {
        background: var(--yellow);
    }
    
    .post-content figure.highlight pre {
        margin: 0;
        padding: 0;
        border: none;
        background: none;
        overflow: visible;
        max-height: none;
    }
    
    .post-content figure.highlight .line {
        display: block;
        min-height: 1.2em;
        line-height: 1.6;
    }
    
    .post-content figure.highlight .gutter {
        border-right: 1px solid rgba(255, 255, 255, 0.1);
        padding-right: 15px;
        margin-right: 15px;
    }
    
    .post-content figure.highlight .gutter pre {
        color: rgba(255, 255, 255, 0.3);
    }
    
    .copy-code-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        padding: 6px 14px;
        background: var(--cyan);
        color: var(--black);
        border: none;
        cursor: pointer;
        font-family: 'Consolas', monospace;
        font-size: 0.75rem;
        font-weight: bold;
        z-index: 10;
        border-radius: 3px;
        transition: all 0.3s ease;
    }
    
    .copy-code-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 0 10px var(--cyan);
        background: var(--yellow);
    }
    
    .hljs {
        background: #282c34 !important;
        color: #abb2bf !important;
    }
    
    .hljs-comment,
    .hljs-quote {
        color: #5c6370 !important;
        font-style: italic;
    }
    
    .hljs-keyword,
    .hljs-selector-tag,
    .hljs-addition {
        color: #c678dd !important;
    }
    
    .hljs-number,
    .hljs-string,
    .hljs-meta .hljs-meta-string,
    .hljs-literal,
    .hljs-doctag,
    .hljs-regexp {
        color: #98c379 !important;
    }
    
    .hljs-title,
    .hljs-section,
    .hljs-name,
    .hljs-selector-id,
    .hljs-selector-class {
        color: #e06c75 !important;
    }
    
    .hljs-attribute,
    .hljs-attr,
    .hljs-variable,
    .hljs-template-variable,
    .hljs-class .hljs-title,
    .hljs-type {
        color: #d19a66 !important;
    }
    
    .hljs-symbol,
    .hljs-bullet,
    .hljs-subst,
    .hljs-meta,
    .hljs-meta .hljs-keyword,
    .hljs-selector-attr,
    .hljs-selector-pseudo,
    .hljs-link {
        color: #61afef !important;
    }
    
    .hljs-built_in,
    .hljs-deletion {
        color: #e06c75 !important;
    }
    
    .hljs-function {
        color: #61afef !important;
    }
    
    .hljs-params {
        color: #abb2bf !important;
    }
</style>
