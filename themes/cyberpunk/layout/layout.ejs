<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page.title ? page.title + ' · ' + config.title : config.title %></title>
    <%- css('css/style.css') %>
    <%- open_graph() %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@1.8.0/dist/umd/lucide.min.js"></script>
</head>
<body>
    <%- include('_partial/header') %>
    <%- body %>
    <%- include('_partial/footer') %>
    <script>lucide.createIcons();</script>
    <%- js('js/main') %>
</body>
</html>
